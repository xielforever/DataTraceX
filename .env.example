# Huawei Cloud credentials. Do not commit real values.
DATATRACEX_HUAWEI_AK=
DATATRACEX_HUAWEI_SK=

# Scope.
DATATRACEX_REGION=cn-north-4
DATATRACEX_PROJECT_ID=
DATATRACEX_WORKSPACE_ID=

# Optional endpoint overrides. Leave empty to use default regional endpoints.
# DataArts Factory V1 jobs: https://dayu-dlf.{region}.myhuaweicloud.com
# DataArts other modules/V2: https://dayu.{region}.myhuaweicloud.com
# CDM: https://cdm.{region}.myhuaweicloud.com
DATATRACEX_DATAARTS_FACTORY_ENDPOINT=
DATATRACEX_DATAARTS_ENDPOINT=
DATATRACEX_CDM_ENDPOINT=
DATATRACEX_CDM_CLUSTER_IDS=

# Harvest behavior.
DATATRACEX_RAW_DIR=data/raw
DATATRACEX_JOB_INSTANCE_DAYS=1

# PostgreSQL fact store.
DATATRACEX_POSTGRES_DSN=postgresql://datatracex:datatracex@127.0.0.1:5432/datatracex

# Neo4j graph projection.
DATATRACEX_NEO4J_URI=bolt://127.0.0.1:7687
DATATRACEX_NEO4J_USER=neo4j
DATATRACEX_NEO4J_PASSWORD=datatracex_graph
